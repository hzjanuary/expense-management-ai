POCKET_LEDGER_ENVIRONMENT=production
POCKET_LEDGER_LOG_LEVEL=INFO
POCKET_LEDGER_DEFAULT_CURRENCY=VND
POCKET_LEDGER_DEFAULT_TIMEZONE=Asia/Ho_Chi_Minh
POCKET_LEDGER_DATABASE_URL=sqlite+aiosqlite:////app/data/pocket_ledger.db
POCKET_LEDGER_DEFAULT_ACCOUNT_NAME=Cash Wallet
POCKET_LEDGER_DEFAULT_ACCOUNT_OPENING_BALANCE_MINOR=1000000

POCKET_LEDGER_OLLAMA_ENABLED=false
POCKET_LEDGER_OLLAMA_BASE_URL=http://host.docker.internal:11434
POCKET_LEDGER_OLLAMA_MODEL=qwen3:4b-instruct
POCKET_LEDGER_OLLAMA_TIMEOUT_SECONDS=10

BACKEND_INTERNAL_URL=http://backend:8010
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8010
BACKEND_PORT=8010
FRONTEND_PORT=3000
