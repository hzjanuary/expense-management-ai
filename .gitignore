# Harness durable layer — each project instance generates its own data.
harness.db
harness.db-wal
harness.db-shm

# Local application database files.
data/
*.db
*.db-wal
*.db-shm

# macOS Finder metadata.
.DS_Store

# Rust build output for harness tooling.
target/
dist/

# JavaScript dependencies for local web UI packages.
node_modules/
*.tsbuildinfo

# Python virtual environments for local backend work.
.venv/

# Python local test, typecheck, and packaging output.
__pycache__/
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/

# Local web UI build and test output.
desktop-dist/
test-results/
tsconfig.tsbuildinfo

# Downloaded Harness CLI binary for installed project instances.
scripts/bin/harness-cli
scripts/bin/harness-cli.exe

# Local Symphony runtime state.
.symphony/
.harness/*
!.harness/changesets/
!.harness/changesets/*.changeset.jsonl
